{
    "bot_template": {
        "type": "template_list",
        "description": "机器人",
        "hint": "可添加多个机器人，每个机器人的记忆独立",
        "templates": {
            "bot_conf": {
                "name": "机器人",
                "items": {
                    "enabled": {
                        "type": "bool",
                        "description": "启用机器人",
                        "default": false,
                        "hint": "启用机器人"
                    },
                    "name": {
                        "description": "机器人名称",
                        "hint": "名称必须唯一，用于索引机器人配置",
                        "type": "str",
                        "default": ""
                    },
                    "nickname": {
                        "description": "机器人名称",
                        "hint": "机器人昵称，用于聊天记录识别",
                        "type": "str",
                        "default": ""
                    },
                    "adapter_ids": {
                        "description": "适配器ID列表",
                        "hint": "通过 /sid 可查看机器人ID，与适配器配置里面填写的机器人名称是一致的。用于多适配器共享记忆或者更换适配器后回溯记忆使用",
                        "type": "list",
                        "default": []
                    },
                    "decision_conf": {
                        "type": "object",
                        "description": "小模型判断配置",
                        "items": {
                            "enabled": {
                                "type": "bool",
                                "description": "启用小模型判断功能",
                                "default": true,
                                "hint": "启用小模型判断功能，如果关闭，将不会触发主动回复功能。"
                            },
                            "provider_ids": {
                                "type": "list",
                                "description": "小模型提供商（按优先级多选）",
                                "_special": "select_providers",
                                "default": [],
                                "hint": "选择用于小模型判断的提供商。若选择多个，第一个失败时会自动降级尝试后面的提供商。留空将跳过使用小模型判断功能。如果使用谷歌API，建议关闭原生搜索功能，否则很容易429"
                            },
                            "group_whitelist": {
                                "description": "白名单群组",
                                "type": "list",
                                "default": [],
                                "hint": "填写数字群号，不填则默认全部群都能触发。"
                            },
                            "decision_prompt": {
                                "type": "text",
                                "editor_mode": true,
                                "editor_language": "markdown",
                                "description": "小模型判断系统提示词",
                                "default": "",
                                "hint": "小模型判断的系统提示词。当前仅支持修改系统提示词，如果要修改用户提示词，请直接修改prompt.py文件。"
                            },
                            "reply_active_window": {
                                "type": "int",
                                "description": "接话分析窗口消息数",
                                "default": 10,
                                "hint": "当机器人发言后，后续多少条群消息会触发分析。设置为0表示只在被@时回复。如果再次发言，该计数会被重置。"
                            },
                            "proactive_probability": {
                                "type": "int",
                                "description": "主动接话触发概率（%）",
                                "default": 0,
                                "hint": "当分析计数为0且没有被@时，群友发来的每条消息按照设定概率（0-100）随机触发一次小模型决策。若决策决定回复，则回复并重置分析计数。"
                            },
                            "keyword_trigger_enabled": {
                                "type": "bool",
                                "description": "启用关键词监听模式",
                                "default": false,
                                "hint": "开启后，当群聊消息中提到设置的兴趣关键词时，将按概率触发小模型分析。"
                            },
                            "keyword_rules": {
                                "type": "list",
                                "description": "兴趣关键词列表",
                                "hint": "当群聊消息中提到这些关键词时触发分析。支持直接输入关键词，或使用『关键词:概率』格式（例如『原神:50』）指定独立触发概率，多个可用英文逗号分隔。",
                                "default": []
                            },
                            "keyword_default_probability": {
                                "type": "int",
                                "description": "关键词默认触发概率（%）",
                                "hint": "当规则中没有指定概率时使用此默认概率",
                                "default": 100
                            }
                        }
                    },
                    "llm_reply_conf": {
                        "type": "object",
                        "description": "大模型回复配置",
                        "items": {
                            "enabled": {
                                "type": "bool",
                                "description": "启用大模型回复功能",
                                "default": false,
                                "hint": "启用大模型回复功能"
                            },
                            "provider_ids": {
                                "type": "list",
                                "description": "大模型回复提供商（按优先级多选）",
                                "_special": "select_providers",
                                "default": [],
                                "hint": "选择用于大模型回复的提供商。若选择多个，第一个失败时会自动降级尝试后面的提供商。留空将跳过使用大模型回复功能。"
                            },
                            "provider_selection_mode": {
                                "type": "string",
                                "description": "多提供商选择模式",
                                "options": [
                                    "fallback",
                                    "random"
                                ],
                                "default": "fallback",
                                "hint": "fallback：按顺序依次尝试主提供商和回退提供商。random：在主提供商和回退提供商中随机打乱顺序使用。"
                            },
                            "llm_reply_prompt": {
                                "type": "text",
                                "editor_mode": true,
                                "editor_language": "markdown",
                                "description": "大模型回复系统提示词",
                                "default": "",
                                "hint": "大模型回复的系统提示词。当前仅支持修改系统提示词，如果要修改用户提示词，请直接修改prompt.py文件。"
                            }
                        }
                    }
                }
            }
        }
    },
    "msg_history": {
        "description": "消息历史配置",
        "type": "object",
        "hint": "",
        "items": {
            "msg_number": {
                "description": "消息历史数量",
                "type": "int",
                "default": 50,
                "hint": "消息历史数量"
            }
        }
    },
    "caption_config": {
        "description": "媒体转述配置",
        "type": "object",
        "hint": "",
        "items": {
            "image_caption_enabled": {
                "description": "启用图片转述",
                "type": "bool",
                "default": true,
                "hint": "即使关闭图片转述，当前消息的图片仍然会与提示词一起发送给LLM。"
            },
            "image_caption_provider_ids": {
                "type": "list",
                "description": "图片转述提供商（按优先级多选）",
                "_special": "select_providers",
                "default": [],
                "hint": "选择用于图片转述的提供商。若选择多个，第一个失败时会自动降级尝试后面的提供商。留空则不启用。"
            },
            "image_caption_system_prompt": {
                "type": "text",
                "editor_mode": true,
                "editor_language": "markdown",
                "description": "图片转述系统提示词",
                "default": "",
                "hint": "图片转述的系统提示词。依旧是只能修改系统提示词。"
            },
            "audio_caption_enabled": {
                "description": "启用音频转述",
                "type": "bool",
                "default": true,
                "hint": "即使关闭音频转述，当前消息的音频仍然会与提示词一起发送给LLM。"
            },
            "audio_caption_provider_ids": {
                "type": "list",
                "description": "音频转述提供商（按优先级多选）",
                "_special": "select_providers",
                "default": [],
                "hint": "选择用于音频转述的提供商。若选择多个，第一个失败时会自动降级尝试后面的提供商。留空则不启用。"
            },
            "audio_caption_system_prompt": {
                "type": "text",
                "editor_mode": true,
                "editor_language": "markdown",
                "description": "音频转述系统提示词",
                "default": "",
                "hint": "音频转述的系统提示词。依旧是只能修改系统提示词。"
            }
        }
    },
    "sticker_config": {
        "description": "表情包配置",
        "type": "object",
        "hint": "",
        "items": {
            "sticker_analysis_prompt": {
                "type": "text",
                "editor_mode": true,
                "editor_language": "markdown",
                "description": "表情包分析系统提示词",
                "default": "",
                "hint": "表情包分析提示词"
            },
            "random_sticker_count": {
                "description": "随机提取表情包数量",
                "type": "int",
                "default": 50,
                "hint": "每次带入大模型上下文的随机表情包数量，过多会影响速度和占用大量Token"
            },
            "sticker_summaries": {
                "description": "表情包外显文字",
                "type": "list",
                "default": ["这是一张表情包"],
                "hint": "发送表情包时外显的文字提示，将会随机抽取一个发送"
            }
        }
    },
    "normal_config": {
        "description": "常规配置",
        "type": "object",
        "hint": "",
        "items": {
            "min_reply_interval": {
                "description": "多条消息最小回复间隔",
                "type": "int",
                "default": 2,
                "hint": "多条消息最小回复间隔"
            },
            "max_reply_interval": {
                "description": "多条消息最大回复间隔",
                "type": "int",
                "default": 5,
                "hint": "多条消息最大回复间隔"
            },
            "energy_recovery_interval": {
                "description": "多少秒能量恢复一个单位能量",
                "type": "int",
                "default": 120,
                "hint": "多少秒恢复一个单位能量。防止机器人把自己能量调到最低假死。"
            }
        }
    },
    "network_config": {
        "description": "网络配置",
        "type": "object",
        "hint": "",
        "items": {
            "decision_retry_times": {
                "description": "决策请求重试上限",
                "type": "int",
                "default": 2,
                "hint": "决策请求重试上限"
            },
            "reply_retry_times": {
                "description": "回复请求重试上限",
                "type": "int",
                "default": 2,
                "hint": "回复请求重试上限"
            },
            "image_caption_retry_times": {
                "description": "图片转述重试上限",
                "type": "int",
                "default": 2,
                "hint": "图片转述重试上限"
            },
            "audio_caption_retry_times": {
                "description": "音频转述重试上限",
                "type": "int",
                "default": 2,
                "hint": "音频转述重试上限"
            }
        }
    },
    "concurrent_config": {
        "description": "并发配置",
        "type": "object",
        "hint": "",
        "items": {
            "concurrent_strategy": {
                "description": "并发策略",
                "type": "string",
                "options": [
                    "stall",
                    "discard"
                ],
                "default": "discard",
                "hint": "stall：挂起超过限制数量的后续消息。discard：丢弃超过限制数量的后续消息。仅影响小模型判断和大模型回复，不影响图片等媒体转述，也不影响消息记录。"
            },
            "concurrent_limit": {
                "description": "并发限制",
                "type": "int",
                "default": 2,
                "hint": "并发限制，超过并发限制将根据策略处理后续消息。节流冷却完后，AI可能还未完成所有回复，可以通过此项防止任务堆积。"
            },
            "user_throttle_time": {
                "description": "用户节流时间",
                "type": "int",
                "default": 10,
                "hint": "开始决策处理后的冷却时间"
            },
            "group_throttle_time": {
                "description": "群组节流时间",
                "type": "int",
                "default": 5,
                "hint": "开始决策处理后的冷却时间"
            },
            "user_debounce_time": {
                "description": "用户防抖",
                "type": "int",
                "default": 3,
                "hint": "用户防抖时间（秒）"
            },
            "user_max_debounce_time": {
                "description": "用户防抖时间上限",
                "type": "int",
                "default": 30,
                "hint": "用户防抖时间上限（秒），超过这个时间直接开始处理"
            }
        }
    },
    "tools_config": {
        "description": "函数调用工具",
        "type": "object",
        "hint": "对于XML格式的工具，这里不再写开关，直接在系统提示词中加入/删除XML代码即可。",
        "items": {
            "use_source_tools": {
                "description": "启用原生函数调用工具",
                "type": "bool",
                "default": true,
                "hint": "启用原生的函数调用工具，需提供商支持。无论是否启用此项，XML工具都可以被调用。"
            },
            "max_loop": {
                "description": "工具调用轮数上限",
                "type": "int",
                "default": 10,
                "hint": "工具调用轮数上限，超过轮数上限将停止调用工具。"
            },
            "timeout": {
                "description": "工具调用超时时间",
                "type": "int",
                "default": 300,
                "hint": "工具调用超时时间，单位秒，超过超时时间将停止调用工具，每个工具独立计时"
            },
            "search_chat_history_enabled": {
                "description": "启用聊天记录检索工具",
                "type": "bool",
                "default": true,
                "hint": "用于AI检索聊天记录"
            },
            "get_message_context_enabled": {
                "description": "启用上下文搜索工具",
                "type": "bool",
                "default": true,
                "hint": "用于AI获取指定消息的上下文"
            }
        }
    },
    "memory_config": {
        "description": "记忆检索配置",
        "type": "object",
        "hint": "当前仅支持本地模型，且仅支持CPU计算。启用此功能需预留至少2GB硬盘空间以及3GB空闲内存。可以使用 /读取记忆 <群号> <问题> 来测试记忆检索功能以及查看相关性得分。",
        "items": {
            "embedding_conf": {
                "type": "object",
                "description": "嵌入模型配置",
                "items": {
                    "enabled": {
                        "description": "启用嵌入模型",
                        "type": "bool",
                        "default": false,
                        "hint": "只有当启动嵌入模型的时候，才支持写入和查询长期记忆。"
                    },
                    "use_external_provider": {
                        "description": "使用 AstrBot 嵌入提供商",
                        "type": "bool",
                        "default": false,
                        "hint": "开启后将使用 AstrBot 中配置的 Embedding 提供商，而不是本地 FastEmbed 模型。"
                    },
                    "external_provider_id": {
                        "description": "外部嵌入提供商 ID",
                        "type": "string",
                        "default": "",
                        "hint": "在使用 AstrBot 提供商时生效。如果不填写，将默认使用 AstrBot 当前激活的第一个嵌入模型。"
                    },
                    "model": {
                        "description": "本地模型名称",
                        "type": "string",
                        "default": "BAAI/bge-small-zh-v1.5",
                        "hint": "本地嵌入模型名称（使用本地 FastEmbed 引擎时生效）。更换模型或提供商后需手动删除插件数据目录下的lancedb文件夹。"
                    },
                    "top_k": {
                        "description": "返回记忆数量",
                        "type": "int",
                        "default": 10,
                        "hint": "返回多少条余弦距离最低的记忆"
                    },
                    "threshold": {
                        "description": "阈值",
                        "type": "float",
                        "default": 0.7,
                        "hint": "余弦距离阈值，高于该阈值的记忆将不会被返回。"
                    },
                    "inject_limit": {
                        "description": "注入记忆数量",
                        "type": "int",
                        "default": 20,
                        "hint": "直接将近期记忆注入上下文，不经过检索，开启后可以适当降低聊天记录的传递数量"
                    }
                }
            },
            "rerank_conf": {
                "type": "object",
                "description": "重排模型配置",
                "items": {
                    "enabled": {
                        "description": "启用重排模型",
                        "type": "bool",
                        "default": false,
                        "hint": "若不开启重排序，嵌入搜索结果将直接作为记忆输入大模型。"
                    },
                    "model": {
                        "description": "模型名称",
                        "type": "string",
                        "default": "BAAI/bge-reranker-base",
                        "hint": "重排模型名称。BAAI/bge-base-zh-v1.5模型权重大小为1.04 GB。如需修改，可用 /打印rerank模型 在控制台查看支持的模型列表。"
                    },
                    "top_k": {
                        "description": "返回记忆数量",
                        "type": "int",
                        "default": 5,
                        "hint": "重排后最多返回多少条记忆。"
                    },
                    "threshold": {
                        "description": "阈值",
                        "type": "float",
                        "default": 0.45,
                        "hint": "BERT文本分类得分，低于该阈值的记忆将不会被返回。"
                    }
                }
            }
        }
    },
    "r2_config": {
        "description": "R2配置",
        "type": "object",
        "hint": "用于备份聊天记录，需自行部署Cloudflare Worker，详见源代码JS注释。嵌入模型的记忆备份暂未实现。",
        "items": {
            "r2_enabled": {
                "description": "启用R2",
                "type": "bool",
                "default": false,
                "hint": "启用R2备份聊天记录功能"
            },
            "backup_time": {
                "description": "备份时间",
                "type": "string",
                "default": "0 * * * *",
                "hint": "cron表达式，例如：0 * * * * 表示每小时备份一次"
            },
            "r2_base_url": {
                "description": "R2 BASE URL",
                "type": "string",
                "default": "",
                "hint": "R2 Worker URL"
            },
            "r2_auth_token": {
                "description": "R2 AUTH TOKEN",
                "type": "string",
                "default": "",
                "hint": "R2鉴权Token，需在Worker的环境变量配置X-Auth-Token"
            }
        }
    },
    "whitelist_config": {
        "description": "白名单配置",
        "type": "object",
        "hint": "",
        "items": {
            "private_chat_bypass_decision_and_whitelist": {
                "description": "私聊免白名单与强制回复",
                "type": "bool",
                "default": true,
                "hint": "开启后，私聊直接触发回复，无需经过小模型决策，也无需经过白名单限制。"
            },
            "group_whitelist_enabled": {
                "description": "启用群组白名单",
                "type": "bool",
                "default": true,
                "hint": "开启后，只响应白名单内的群组"
            },
            "group_whitelist": {
                "description": "群组UMO白名单",
                "type": "list",
                "default": [],
                "hint": "白名单群组UMO列表，可在对应群内使用/sid获取。要把UMO写完整。"
            },
            "user_whitelist_enabled": {
                "description": "启用用户白名单",
                "type": "bool",
                "default": false,
                "hint": "开启后，只响应白名单内的用户"
            },
            "user_whitelist": {
                "description": "用户ID白名单",
                "type": "list",
                "default": [],
                "hint": "用户ID列表"
            }
        }
    }
}