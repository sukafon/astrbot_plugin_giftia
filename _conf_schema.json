{
    "bot_template": {
        "type": "template_list",
        "description": "机器人",
        "hint": "可添加多个机器人，每个机器人的记忆独立",
        "templates": {
            "bot_conf": {
                "name": "机器人",
                "items": {
                    "enabled": {
                        "type": "bool",
                        "description": "启用机器人",
                        "default": false,
                        "hint": "启用机器人"
                    },
                    "name": {
                        "description": "机器人名称",
                        "hint": "名称必须唯一，用于索引机器人配置",
                        "type": "str",
                        "default": ""
                    },
                    "nickname": {
                        "description": "机器人名称",
                        "hint": "机器人昵称，用于聊天记录识别",
                        "type": "str",
                        "default": ""
                    },
                    "adapter_ids": {
                        "description": "适配器ID列表",
                        "hint": "通过 /sid 可查看机器人ID，与适配器配置里面填写的机器人名称是一致的。用于多适配器共享记忆或者更换适配器后回溯记忆使用",
                        "type": "list",
                        "default": []
                    },
                    "decision_conf": {
                        "type": "object",
                        "description": "小模型判断配置",
                        "items": {
                            "enabled": {
                                "type": "bool",
                                "description": "启用小模型判断功能",
                                "default": true,
                                "hint": "启用小模型判断功能，如果关闭，将不会触发主动回复功能。"
                            },
                            "provider_ids": {
                                "type": "list",
                                "description": "小模型提供商（按优先级多选）",
                                "_special": "select_providers",
                                "default": [],
                                "hint": "选择用于小模型判断的提供商。若选择多个，第一个失败时会自动降级尝试后面的提供商。留空将跳过使用小模型判断功能。如果使用谷歌API，建议关闭原生搜索功能，否则很容易429"
                            },
                            "group_whitelist": {
                                "description": "白名单群组",
                                "type": "list",
                                "default": [],
                                "hint": "填写数字群号，不填则默认全部群都能触发。"
                            },
                            "decision_prompt": {
                                "type": "text",
                                "editor_mode": true,
                                "editor_language": "markdown",
                                "description": "小模型判断系统提示词",
                                "default": "",
                                "hint": "小模型判断的系统提示词。当前仅支持修改系统提示词，如果要修改用户提示词，请直接修改prompt.py文件。"
                            },
                            "reply_active_window": {
                                "type": "int",
                                "description": "接话分析窗口消息数",
                                "default": 10,
                                "hint": "当机器人发言后，后续多少条群消息会触发分析。设置为0表示只在被@时回复。如果再次发言，该计数会被重置。"
                            },
                            "proactive_probability": {
                                "type": "int",
                                "description": "主动接话触发概率（%）",
                                "default": 0,
                                "hint": "当分析计数为0且没有被@时，群友发来的每条消息按照设定概率（0-100）随机触发一次小模型决策。若决策决定回复，则回复并重置分析计数。"
                            },
                            "keyword_trigger_enabled": {
                                "type": "bool",
                                "description": "启用关键词监听模式",
                                "default": false,
                                "hint": "开启后，当群聊消息中提到设置的兴趣关键词时，将按概率触发小模型分析。"
                            },
                            "keyword_rules": {
                                "type": "list",
                                "description": "兴趣关键词列表",
                                "hint": "当群聊消息中提到这些关键词时触发分析。支持直接输入关键词，或使用『关键词:概率』格式（例如『原神:50』）指定独立触发概率，多个可用英文逗号分隔。",
                                "default": []
                            },
                            "keyword_default_probability": {
                                "type": "int",
                                "description": "关键词默认触发概率（%）",
                                "hint": "当规则中没有指定概率时使用此默认概率",
                                "default": 100
                            }
                        }
                    },
                    "llm_reply_conf": {
                        "type": "object",
                        "description": "大模型回复配置",
                        "items": {
                            "enabled": {
                                "type": "bool",
                                "description": "启用大模型回复功能",
                                "default": false,
                                "hint": "启用大模型回复功能"
                            },
                            "provider_ids": {
                                "type": "list",
                                "description": "大模型回复提供商（按优先级多选）",
                                "_special": "select_providers",
                                "default": [],
                                "hint": "选择用于大模型回复的提供商。若选择多个，第一个失败时会自动降级尝试后面的提供商。留空将跳过使用大模型回复功能。"
                            },
                            "provider_selection_mode": {
                                "type": "string",
                                "description": "多提供商选择模式",
                                "options": [
                                    "fallback",
                                    "random"
                                ],
                                "default": "fallback",
                                "hint": "fallback：按顺序依次尝试主提供商和回退提供商。random：在主提供商和回退提供商中随机打乱顺序使用。"
                            },
                            "llm_reply_prompt": {
                                "type": "text",
                                "editor_mode": true,
                                "editor_language": "markdown",
                                "description": "大模型回复系统提示词",
                                "default": "",
                                "hint": "大模型回复的系统提示词。当前仅支持修改系统提示词，如果要修改用户提示词，请直接修改prompt.py文件。"
                            }
                        }
                    }
                }
            }
        }
    },
    "msg_history": {
        "description": "消息历史配置",
        "type": "object",
        "hint": "",
        "items": {
            "msg_number": {
                "description": "消息历史数量",
                "type": "int",
                "default": 50,
                "hint": "消息历史数量"
            }
        }
    },
    "caption_config": {
        "description": "媒体转述配置",
        "type": "object",
        "hint": "",
        "items": {
            "image_caption_enabled": {
                "description": "启用图片转述",
                "type": "bool",
                "default": true,
                "hint": "即使关闭图片转述，当前消息的图片仍然会与提示词一起发送给LLM。"
            },
            "image_caption_provider_ids": {
                "type": "list",
                "description": "图片转述提供商（按优先级多选）",
                "_special": "select_providers",
                "default": [],
                "hint": "选择用于图片转述的提供商。若选择多个，第一个失败时会自动降级尝试后面的提供商。留空则不启用。"
            },
            "audio_caption_enabled": {
                "description": "启用音频转述",
                "type": "bool",
                "default": true,
                "hint": "即使关闭音频转述，当前消息的音频仍然会与提示词一起发送给LLM。"
            },
            "audio_caption_provider_ids": {
                "type": "list",
                "description": "音频转述提供商（按优先级多选）",
                "_special": "select_providers",
                "default": [],
                "hint": "选择用于音频转述的提供商。若选择多个，第一个失败时会自动降级尝试后面的提供商。留空则不启用。"
            },
            "defer_caption_enabled": {
                "description": "按需延迟媒体转述",
                "type": "bool",
                "default": true,
                "hint": "在群组未活跃或机器人未被直接召唤时，不立刻调用大模型进行媒体（图片/语音）转述，直到决定回复时再按需补全转述，极大减少Token消耗。"
            },
            "max_deferred_captions": {
                "description": "单次补全转述上限",
                "type": "int",
                "default": 5,
                "hint": "当触发按需补全转述时，一次回复流程中最多对多少个未转述的媒体进行转述（避免上下文内未转述媒体过多时单次产生过多LLM调用）。"
            }
        }
    },
    "tts_config": {
        "description": "TTS XML 语音配置",
        "type": "object",
        "hint": "开启后会向大模型回复提示词注入 <tts lang=\"ja-JP\" emotion=\"happy\">语音文本</tts> 标签说明。语言与供应商映射列表的第一项会作为默认语言和默认供应商。",
        "items": {
            "enabled": {
                "description": "启用 TTS XML 输出",
                "type": "bool",
                "default": false,
                "hint": "开启后，大模型可输出 <tts> 标签，由插件按语言映射调用 AstrBot 的 TTS 供应商发送语音。"
            },
            "provider_type": {
                "description": "TTS 供应商类型",
                "type": "string",
                "options": [
                    "minimax",
                    "fishaudio"
                ],
                "default": "minimax",
                "hint": "影响提示词中的标签与情绪规则。MiniMax 使用固定情绪枚举和括号语气词；FishAudio 使用自由方括号标签。"
            },
            "language_provider_map": {
                "type": "template_list",
                "description": "语言与 AstrBot TTS 供应商映射",
                "hint": "目前只支持中文、英文、日文。请为每种语言选择与上方供应商类型相同的 AstrBot TTS 供应商；列表第一项会作为默认语言和默认供应商。",
                "templates": {
                    "language_provider": {
                        "name": "语言供应商映射",
                        "items": {
                            "language": {
                                "description": "语言",
                                "type": "string",
                                "options": [
                                    "中文",
                                    "英文",
                                    "日文"
                                ],
                                "default": "中文",
                                "hint": "配置界面显示中文名，插件内部会映射为 zh-CN、en-US、ja-JP。"
                            },
                            "provider_id": {
                                "description": "AstrBot TTS 供应商",
                                "type": "string",
                                "_special": "select_provider_tts",
                                "default": "",
                                "hint": "请选择与 TTS 供应商类型一致的 AstrBot TTS 供应商，例如 minimax 对应 MiniMax TTS，fishaudio 对应 FishAudio TTS。"
                            }
                        }
                    }
                }
            },
            "signature_voices": {
                "type": "template_list",
                "description": "标志性语音替换列表",
                "hint": "配置标志性发言文本与语音文件的映射。如果合成的语音文本匹配，将直接发送对应语音文件。",
                "templates": {
                    "signature_voice_item": {
                        "name": "语音映射项",
                        "items": {
                            "audio": {
                                "description": "语音文件",
                                "type": "file",
                                "file_types": [
                                    "wav",
                                    "mp3",
                                    "ogg",
                                    "amr",
                                    "wma",
                                    "m4a",
                                    "silk"
                                ],
                                "default": "",
                                "hint": "上传或选择本条标志性发言对应的语音文件"
                            },
                            "matched_texts": {
                                "description": "匹配文本列表",
                                "type": "list",
                                "default": [],
                                "hint": "可匹配的多个发言文本，例如 ['你好', 'hello', '嗨']"
                            }
                        }
                    }
                }
            },
            "replace_in_message": {
                "description": "从普通文本消息中替换",
                "type": "bool",
                "default": false,
                "hint": "开启后，普通文本消息中的首尾标志性发言也会被摘出并直接发送语音。"
            }
        }
    },
    "sticker_config": {
        "description": "表情包配置",
        "type": "object",
        "hint": "",
        "items": {
            "random_sticker_count": {
                "description": "随机提取表情包数量",
                "type": "int",
                "default": 50,
                "hint": "每次带入大模型上下文的随机表情包数量，过多会影响速度和占用大量Token"
            },
            "sticker_summaries": {
                "description": "表情包外显文字",
                "type": "list",
                "default": [
                    "这是一张表情包"
                ],
                "hint": "发送表情包时外显的文字提示，将会随机抽取一个发送"
            }
        }
    },
    "normal_config": {
        "description": "常规配置",
        "type": "object",
        "hint": "",
        "items": {
            "min_reply_interval": {
                "description": "多条消息最小回复间隔",
                "type": "int",
                "default": 2,
                "hint": "多条消息最小回复间隔"
            },
            "max_reply_interval": {
                "description": "多条消息最大回复间隔",
                "type": "int",
                "default": 5,
                "hint": "多条消息最大回复间隔"
            },
            "energy_recovery_interval": {
                "description": "多少秒能量恢复一个单位能量",
                "type": "int",
                "default": 120,
                "hint": "多少秒恢复一个单位能量。防止机器人把自己能量调到最低假死。"
            },
            "reply_message_truncate_limit": {
                "description": "回复上下文单条消息截断字数",
                "type": "int",
                "default": 1500,
                "hint": "生成回复/决策提示词时单条消息的最大字数限制（防长日志或代码爆上下文/Token），超出的部分将被截断。设为 0 或负数表示不截断。"
            },
            "safety_intercept_keywords": {
                "description": "安全拦截关键词列表",
                "type": "list",
                "default": [],
                "hint": "当用户发送的消息中包含该列表中的任意关键词时，入库和上下文中的消息内容将被自动替换为【该消息触发了安全拦截，已被屏蔽】，以防止 Bot 遭到大模型敏感安全拦截。"
            }
        }
    },
    "network_config": {
        "description": "网络配置",
        "type": "object",
        "hint": "",
        "items": {
            "decision_retry_times": {
                "description": "决策请求重试上限",
                "type": "int",
                "default": 2,
                "hint": "决策请求重试上限"
            },
            "reply_retry_times": {
                "description": "回复请求重试上限",
                "type": "int",
                "default": 2,
                "hint": "回复请求重试上限"
            },
            "image_caption_retry_times": {
                "description": "图片转述重试上限",
                "type": "int",
                "default": 2,
                "hint": "图片转述重试上限"
            },
            "audio_caption_retry_times": {
                "description": "音频转述重试上限",
                "type": "int",
                "default": 2,
                "hint": "音频转述重试上限"
            }
        }
    },
    "concurrent_config": {
        "description": "并发配置",
        "type": "object",
        "hint": "",
        "items": {
            "concurrent_strategy": {
                "description": "并发策略",
                "type": "string",
                "options": [
                    "stall",
                    "discard"
                ],
                "default": "discard",
                "hint": "stall：挂起超过限制数量的后续消息。discard：丢弃超过限制数量的后续消息。仅影响小模型判断和大模型回复，不影响图片等媒体转述，也不影响消息记录。"
            },
            "concurrent_limit": {
                "description": "并发限制",
                "type": "int",
                "default": 2,
                "hint": "并发限制，超过并发限制将根据策略处理后续消息。节流冷却完后，AI可能还未完成所有回复，可以通过此项防止任务堆积。"
            },
            "user_throttle_time": {
                "description": "用户节流时间",
                "type": "int",
                "default": 10,
                "hint": "开始决策处理后的冷却时间"
            },
            "group_throttle_time": {
                "description": "群组节流时间",
                "type": "int",
                "default": 5,
                "hint": "开始决策处理后的冷却时间"
            },
            "user_debounce_time": {
                "description": "用户防抖",
                "type": "int",
                "default": 3,
                "hint": "用户防抖时间（秒）"
            },
            "user_max_debounce_time": {
                "description": "用户防抖时间上限",
                "type": "int",
                "default": 30,
                "hint": "用户防抖时间上限（秒），超过这个时间直接开始处理"
            }
        }
    },
    "tools_config": {
        "description": "函数调用工具",
        "type": "object",
        "hint": "对于XML格式的工具，这里不再写开关，直接在系统提示词中加入/删除XML代码即可。",
        "items": {
            "use_source_tools": {
                "description": "启用原生函数调用工具",
                "type": "bool",
                "default": true,
                "hint": "启用原生的函数调用工具，需提供商支持。无论是否启用此项，XML工具都可以被调用。"
            },
            "force_xml_tools": {
                "description": "强制使用 XML 标签调用工具",
                "type": "bool",
                "default": false,
                "hint": "开启后，将从原生工具列表中获取工具，并以 XML 格式写入系统提示词，而不会将原生 tools 结构传给 LLM（对模型遵循指令能力要求较高，建议在能力较强的模型上使用）。"
            },
            "max_loop": {
                "description": "工具调用轮数上限",
                "type": "int",
                "default": 10,
                "hint": "工具调用轮数上限，超过轮数上限将停止调用工具。"
            },
            "timeout": {
                "description": "工具调用超时时间",
                "type": "int",
                "default": 300,
                "hint": "工具调用超时时间，单位秒，超过超时时间将停止调用工具，每个工具独立计时"
            },
            "search_chat_history_enabled": {
                "description": "启用聊天记录检索工具",
                "type": "bool",
                "default": true,
                "hint": "用于AI检索聊天记录"
            },
            "get_message_context_enabled": {
                "description": "启用上下文搜索工具",
                "type": "bool",
                "default": true,
                "hint": "用于AI获取指定消息的上下文"
            },
            "search_user_profile_enabled": {
                "description": "启用用户画像查询工具",
                "type": "bool",
                "default": true,
                "hint": "允许AI在当前会话内通过用户ID、昵称、你的称呼或其他外号模糊查询成员画像"
            },
            "inspect_forward_message_enabled": {
                "description": "启用合并转发按需查看工具",
                "type": "bool",
                "default": true,
                "hint": "允许AI在需要时按forward_id查看合并转发消息内容，默认提示词只暴露轻量索引"
            },
            "inspect_forward_max_media_captions": {
                "description": "转发查看工具最多转述媒体数",
                "type": "int",
                "default": 5,
                "hint": "inspect_forward_message 被调用时，单次最多触发多少个转发内图片/语音转述"
            },
            "inspect_forward_raw_threshold": {
                "description": "转发查看工具原文返回阈值",
                "type": "int",
                "default": 20,
                "hint": "合并转发节点数不超过该值时直接返回原文，超过时才生成并复用总结"
            },
            "active_user_brief_limit": {
                "description": "活跃用户摘要数量",
                "type": "int",
                "default": 10,
                "hint": "回复和决策提示词中最多注入多少个消息窗口内其他活跃用户的轻量画像摘要"
            },
            "task_board_default_expire_hours": {
                "description": "短期任务默认过期小时数",
                "type": "int",
                "default": 24,
                "hint": "模型创建短期任务时若没有指定过期时间，任务会在创建后多少小时自动过期。默认 24 小时。"
            },
            "task_board_max_active": {
                "description": "每会话活跃任务上限",
                "type": "int",
                "default": 3,
                "hint": "同一个 Bot 在同一会话中最多保留多少条进行中的短期任务。达到上限后系统会拒绝继续创建。"
            },
            "enabled_interactive_features": {
                "description": "启用的内置交互功能",
                "hint": "勾选表示启用对应的内置互动/功能 XML 标签，大模型将只能输出勾选的标签。",
                "type": "list",
                "options": [
                    "poke(戳一戳)",
                    "emoji_like(贴表情回应)",
                    "repeat(消息复读)",
                    "like(点赞名片)",
                    "delete(撤回自身消息)",
                    "group_admin(群管禁言/踢人)",
                    "schedule_task(设置/查看/删除定时任务)",
                    "task_board(短期任务看板)",
                    "leave(退群)",
                    "sticker(表情包发送与收集)",
                    "memory_query_delete(记忆查询与删除)"
                ],
                "default": [
                    "poke(戳一戳)",
                    "emoji_like(贴表情回应)",
                    "repeat(消息复读)",
                    "like(点赞名片)",
                    "delete(撤回自身消息)",
                    "group_admin(群管禁言/踢人)",
                    "schedule_task(设置/查看/删除定时任务)",
                    "task_board(短期任务看板)",
                    "sticker(表情包发送与收集)",
                    "memory_query_delete(记忆查询与删除)"
                ]
            }
        }
    },
    "memory_config": {
        "description": "记忆检索配置",
        "type": "object",
        "hint": "当前仅支持本地模型，且仅支持CPU计算。启用此功能需预留至少2GB硬盘空间以及3GB空闲内存。可以使用 /读取记忆 <群号> <问题> 来测试记忆检索功能以及查看相关性得分。",
        "items": {
            "embedding_conf": {
                "type": "object",
                "description": "嵌入模型配置",
                "items": {
                    "enabled": {
                        "description": "启用嵌入模型",
                        "type": "bool",
                        "default": false,
                        "hint": "只有当启动嵌入模型的时候，才支持写入和查询长期记忆。"
                    },
                    "use_external_provider": {
                        "description": "使用 AstrBot 嵌入提供商",
                        "type": "bool",
                        "default": false,
                        "hint": "开启后将使用 AstrBot 中配置的 Embedding 提供商，而不是本地 FastEmbed 模型。"
                    },
                    "external_provider_id": {
                        "description": "外部嵌入提供商 ID",
                        "type": "string",
                        "default": "",
                        "hint": "在使用 AstrBot 提供商时生效。如果不填写，将默认使用 AstrBot 当前激活的第一个嵌入模型。"
                    },
                    "model": {
                        "description": "本地模型名称",
                        "type": "string",
                        "default": "BAAI/bge-small-zh-v1.5",
                        "hint": "本地嵌入模型名称（使用本地 FastEmbed 引擎时生效）。更换模型或提供商后需手动删除插件数据目录下的lancedb文件夹。"
                    },
                    "top_k": {
                        "description": "返回记忆数量",
                        "type": "int",
                        "default": 10,
                        "hint": "返回多少条余弦距离最低的记忆"
                    },
                    "threshold": {
                        "description": "阈值",
                        "type": "float",
                        "default": 0.7,
                        "hint": "余弦距离阈值，高于该阈值的记忆将不会被返回。"
                    },
                    "inject_limit": {
                        "description": "注入记忆数量",
                        "type": "int",
                        "default": 20,
                        "hint": "会话召回池开启时，控制提示词中最多注入多少条会话召回记忆，同时作为会话召回池容量上限。关闭会话召回池时，控制旧式近期记忆直接注入数量。设置为 0 可关闭记忆自动注入。"
                    },
                    "session_recall_enabled": {
                        "description": "启用会话召回池",
                        "type": "bool",
                        "default": true,
                        "hint": "开启后，每次机器人被唤醒都会用当前消息语义召回长期记忆，并在当前会话内累积为临时工作记忆。"
                    },
                    "session_recall_search_limit": {
                        "description": "单次候选召回数量",
                        "type": "int",
                        "default": 3,
                        "hint": "每条新消息最多从长期记忆中召回多少条候选记忆。开启重排序时，会先召回候选，再由重排序配置继续筛选。"
                    },
                    "session_recall_ttl_seconds": {
                        "description": "会话召回保留时间",
                        "type": "int",
                        "default": 1800,
                        "hint": "一条临时召回记忆多久没有再次命中后可被清理。设置为 0 表示不按时间清理，只在超出上限时清理。"
                    }
                }
            },
            "rerank_conf": {
                "type": "object",
                "description": "重排模型配置",
                "items": {
                    "enabled": {
                        "description": "启用重排模型",
                        "type": "bool",
                        "default": false,
                        "hint": "若不开启重排序，嵌入搜索结果将直接作为记忆输入大模型。"
                    },
                    "use_external_provider": {
                        "description": "使用 AstrBot 重排序提供商",
                        "type": "bool",
                        "default": false,
                        "hint": "开启后将使用 AstrBot 中配置的 Rerank 提供商，而不是本地 FastEmbed 重排模型。"
                    },
                    "external_provider_id": {
                        "description": "外部重排序提供商 ID",
                        "type": "string",
                        "default": "",
                        "hint": "在使用 AstrBot 提供商时生效。如果不填写，将默认使用 AstrBot 当前激活的第一个重排序模型。"
                    },
                    "model": {
                        "description": "本地重排模型名称",
                        "type": "string",
                        "default": "BAAI/bge-reranker-base",
                        "hint": "仅在未开启“使用 AstrBot 重排序提供商”时生效。本地 FastEmbed 重排模型名称，例如 BAAI/bge-reranker-base。如需修改，可用 /打印rerank模型 在控制台查看支持的本地模型列表。"
                    },
                    "top_k": {
                        "description": "返回记忆数量",
                        "type": "int",
                        "default": 5,
                        "hint": "重排后最多返回多少条记忆。"
                    },
                    "threshold": {
                        "description": "阈值",
                        "type": "float",
                        "default": 0.45,
                        "hint": "BERT文本分类得分，低于该阈值的记忆将不会被返回。"
                    }
                }
            },
            "passive_memory_enabled": {
                "description": "启用被动状态维护",
                "type": "bool",
                "default": false,
                "hint": "开启后，机器人会在后台自动对参与过的群聊片段进行总结，并分别更新长期记忆、用户画像、群画像、好感度和关系头衔。未启用嵌入模型时会跳过长期记忆入库，但仍可维护画像。"
            },
            "passive_memory_provider_ids": {
                "type": "list",
                "description": "被动总结模型提供商",
                "_special": "select_providers",
                "default": [],
                "hint": "选择用于后台长期记忆提炼与画像维护的 LLM 提供商。如果不配置，将跳过后台总结。后台任务为异步执行，不占用回复通道。"
            },
            "passive_memory_silence_threshold": {
                "description": "被动总结静默触发阈值",
                "type": "int",
                "default": 10,
                "hint": "机器人静默多少条消息后触发后台总结（与接话分析窗口数 W 叠加，即机器人最后一次发言后累计收到 W + N 条消息后触发）。"
            },
            "passive_memory_overflow_threshold": {
                "description": "被动总结溢出触发阈值",
                "type": "int",
                "default": 100,
                "hint": "当机器人一直活跃时，未总结且已离开上下文窗口的消息达到多少条后触发后台记录。"
            }
        }
    },
